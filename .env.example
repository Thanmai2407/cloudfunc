# ☁️ CloudFunc Environment Configuration Example
# Copy this to .env in each service directory as needed, or let Docker Compose load it.

# API Gateway Configuration
GATEWAY_PORT=5001

# Function Registry Configuration
REGISTRY_PORT=8080
REGISTRY_URL=http://localhost:8080

# Container Manager Configuration
CONTAINER_PORT=3000
CONTAINER_URL=http://localhost:3000

# Worker health API port
WORKER_PORT=5002

# RabbitMQ Connection Details
RABBITMQ_URL=amqp://localhost:5672

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cloudfunc

# Sandbox Policies & Resource Limits
EXECUTION_TIMEOUT=5000
MAX_RETRIES=3
IDLE_CONTAINER_TTL_MS=300000
